{% extends 'layouts/master.twig' %}

{% block content %}

{# ─── BREADCRUMB ─── #}
<nav class="breadcrumb" aria-label="{{ 'breadcrumb' | trans }}">
  <div class="breadcrumb-inner">
    <a href="{{ store.url }}">{{ 'home' | trans }}</a>
    <span aria-hidden="true">›</span>
    <a href="{{ store.urls.products }}">{{ 'products' | trans }}</a>
    {% if product.category %}
      <span aria-hidden="true">›</span>
      <a href="{{ product.category.url }}">{{ product.category.name }}</a>
    {% endif %}
    <span aria-hidden="true">›</span>
    <span aria-current="page">{{ product.name }}</span>
  </div>
</nav>

{# ─── PRODUCT MAIN ─── #}
<section class="product-single" itemscope itemtype="https://schema.org/Product">
  <div class="product-single-inner">

    {# ─── GALLERY ─── #}
    <div class="product-gallery">
      <div class="gallery-thumbs" role="list">
        {% for image in product.images %}
          <button
            class="thumb {% if loop.first %}active{% endif %}"
            data-img="{{ image.url }}"
            aria-label="{{ 'image' | trans }} {{ loop.index }}"
            role="listitem">
            <img src="{{ image.url }}" alt="{{ product.name }} {{ loop.index }}" loading="lazy">
          </button>
        {% endfor %}
      </div>

      <div class="gallery-main">
        <img
          id="main-product-img"
          src="{{ product.images[0].url ?? product.image.url }}"
          alt="{{ product.name }}"
          itemprop="image"
          loading="eager"
          fetchpriority="high">

        {% if product.sale_price %}
          {% set discount = ((product.price - product.sale_price) / product.price * 100) | round %}
          <span class="gallery-badge badge badge-sale">-{{ discount }}%</span>
        {% elseif product.is_new %}
          <span class="gallery-badge badge badge-new">{{ 'new' | trans }}</span>
        {% endif %}

        <salla-favorite-btn product-id="{{ product.id }}" class="gallery-wishlist"></salla-favorite-btn>
      </div>
    </div>

    {# ─── PRODUCT INFO ─── #}
    <div class="product-info">

      {# Brand #}
      {% if product.brand %}
        <a href="{{ product.brand.url }}" class="product-brand">{{ product.brand.name }}</a>
      {% endif %}

      {# Name #}
      <h1 class="product-single-name" itemprop="name">{{ product.name }}</h1>

      {# Rating #}
      {% if product.rating %}
        <div class="product-rating" aria-label="{{ product.rating }} {{ 'stars' | trans }}">
          {% for i in 1..5 %}
            <span class="{% if i <= product.rating %}star-filled{% else %}star-empty{% endif %}">★</span>
          {% endfor %}
          <span class="rating-count">({{ product.reviews_count }} {{ 'review' | trans }})</span>
        </div>
      {% endif %}

      {# Price #}
      <div class="product-single-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <salla-price
          amount="{{ product.sale_price ?? product.price }}"
          currency="{{ store.currency }}"
          class="price-main"
        ></salla-price>
        {% if product.sale_price %}
          <salla-price
            amount="{{ product.price }}"
            currency="{{ store.currency }}"
            class="price-old"
            strikethrough
          ></salla-price>
        {% endif %}
        <meta itemprop="price" content="{{ product.sale_price ?? product.price }}">
        <meta itemprop="priceCurrency" content="{{ store.currency }}">
      </div>

      <div class="product-divider"></div>

      {# Options (Color, Size, etc.) #}
      {% if product.options %}
        <salla-product-options product-id="{{ product.id }}"></salla-product-options>
      {% endif %}

      {# Quantity + Add to Cart #}
      <div class="product-purchase">
        <div class="qty-wrap">
          <label class="qty-label" for="product-qty">{{ 'quantity' | trans }}</label>
          <salla-quantity-input
            id="product-qty"
            min="1"
            max="{{ product.quantity }}"
            value="1"
          ></salla-quantity-input>
        </div>

        <salla-add-product-button
          product-id="{{ product.id }}"
          class="btn-add-cart"
          label="{{ 'add_to_cart' | trans }}"
        ></salla-add-product-button>
      </div>

      {# Buy Now #}
      <salla-buy-now-button
        product-id="{{ product.id }}"
        class="btn-buy-now"
        label="{{ 'buy_now' | trans }}"
      ></salla-buy-now-button>

      <div class="product-divider"></div>

      {# Short Description #}
      {% if product.short_description %}
        <p class="product-short-desc">{{ product.short_description }}</p>
      {% endif %}

      {# Meta info #}
      <div class="product-meta">
        {% if product.sku %}
          <div class="meta-row">
            <span class="meta-label">{{ 'sku' | trans }}</span>
            <span class="meta-val">{{ product.sku }}</span>
          </div>
        {% endif %}
        {% if product.category %}
          <div class="meta-row">
            <span class="meta-label">{{ 'category' | trans }}</span>
            <a href="{{ product.category.url }}" class="meta-val">{{ product.category.name }}</a>
          </div>
        {% endif %}
        <div class="meta-row">
          <span class="meta-label">{{ 'availability' | trans }}</span>
          <span class="meta-val {% if product.quantity > 0 %}in-stock{% else %}out-of-stock{% endif %}">
            {{ product.quantity > 0 ? ('in_stock' | trans) : ('out_of_stock' | trans) }}
          </span>
        </div>
      </div>

      {# Share #}
      <salla-share product-id="{{ product.id }}"></salla-share>

    </div>
  </div>

  {# ─── TABS: Description / Specs / Reviews ─── #}
  <div class="product-tabs-section">
    <div class="product-tabs-nav" role="tablist">
      <button class="tab active" role="tab" aria-selected="true" aria-controls="tab-desc" id="btn-desc">
        {{ 'description' | trans }}
      </button>
      {% if product.specifications %}
        <button class="tab" role="tab" aria-selected="false" aria-controls="tab-specs" id="btn-specs">
          {{ 'specifications' | trans }}
        </button>
      {% endif %}
      <button class="tab" role="tab" aria-selected="false" aria-controls="tab-reviews" id="btn-reviews">
        {{ 'reviews' | trans }} ({{ product.reviews_count | default(0) }})
      </button>
    </div>

    <div id="tab-desc" class="tab-panel active" role="tabpanel" aria-labelledby="btn-desc">
      <div class="product-description" itemprop="description">
        {{ product.description | raw }}
      </div>
    </div>

    {% if product.specifications %}
      <div id="tab-specs" class="tab-panel" role="tabpanel" aria-labelledby="btn-specs" hidden>
        <table class="specs-table">
          {% for spec in product.specifications %}
            <tr>
              <th>{{ spec.name }}</th>
              <td>{{ spec.value }}</td>
            </tr>
          {% endfor %}
        </table>
      </div>
    {% endif %}

    <div id="tab-reviews" class="tab-panel" role="tabpanel" aria-labelledby="btn-reviews" hidden>
      <salla-rating-stars product-id="{{ product.id }}"></salla-rating-stars>
    </div>
  </div>

</section>

{# ─── RELATED PRODUCTS ─── #}
{% if product.related_products %}
  <section class="related-products">
    <div class="products-inner">
      <div class="section-header reveal">
        <span class="section-tag">{{ 'you_may_also_like' | trans }}</span>
        <h2 class="section-title">{{ 'related_products' | trans }}</h2>
      </div>
      <div class="products-grid">
        {% for related in product.related_products | slice(0, 4) %}
          {% include 'product/card.twig' with { product: related } %}
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% endblock %}
