<article class="product-card reveal" itemscope itemtype="https://schema.org/Product">

  <div class="product-img-wrap">

    {# Product Badges #}
    <div class="product-badges">
      {% if product.is_new %}
        <span class="badge badge-new">{{ 'new' | trans }}</span>
      {% endif %}
      {% if product.sale_price %}
        {% set discount = ((product.price - product.sale_price) / product.price * 100) | round %}
        <span class="badge badge-sale">-{{ discount }}%</span>
      {% endif %}
    </div>

    {# Product Image #}
    <a href="{{ product.url }}" tabindex="-1" aria-hidden="true">
      <img
        src="{{ product.image.url }}"
        alt="{{ product.name }}"
        itemprop="image"
        loading="lazy"
        width="400"
        height="533">
    </a>

    {# Quick Add to Cart — Salla Web Component #}
    <div class="product-actions">
      <salla-add-product-button
        product-id="{{ product.id }}"
        label="{{ 'add_to_cart' | trans }} ✦"
      ></salla-add-product-button>
    </div>

    {# Wishlist #}
    <salla-favorite-btn product-id="{{ product.id }}" class="product-wishlist"></salla-favorite-btn>

  </div>

  {# Color Options #}
  {% if product.options %}
    <div class="product-colors" role="list" aria-label="{{ 'colors' | trans }}">
      {% for option in product.options | filter(o => o.type == 'color') | slice(0, 4) %}
        <span
          class="color-dot {% if loop.first %}active{% endif %}"
          style="background: {{ option.color }}"
          title="{{ option.name }}"
          role="listitem"
        ></span>
      {% endfor %}
    </div>
  {% endif %}

  {# Info #}
  <a href="{{ product.url }}" class="product-name" itemprop="name">{{ product.name }}</a>
  {% if product.subtitle %}
    <p class="product-type">{{ product.subtitle }}</p>
  {% endif %}

  {# Price — Salla Web Component #}
  <div class="product-price">
    <salla-price
      amount="{{ product.sale_price ?? product.price }}"
      currency="{{ store.currency }}"
    ></salla-price>
    {% if product.sale_price %}
      <salla-price
        amount="{{ product.price }}"
        currency="{{ store.currency }}"
        class="price-old"
        strikethrough
      ></salla-price>
    {% endif %}
  </div>

</article>
