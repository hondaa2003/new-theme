{% extends 'layouts/master.twig' %}
{% block content %}
<div class="page-hero">
  <div class="page-hero-inner">
    <h1 class="section-title">{{ 'brands' | trans }}</h1>
  </div>
</div>
<div class="section">
  <div class="brands-grid">
    {% for brand in brands %}
      <a href="{{ brand.url }}" class="brand-card reveal">
        {% if brand.logo %}
          <img src="{{ brand.logo }}" alt="{{ brand.name }}">
        {% else %}
          <span>{{ brand.name }}</span>
        {% endif %}
      </a>
    {% endfor %}
  </div>
</div>
{% endblock %}
