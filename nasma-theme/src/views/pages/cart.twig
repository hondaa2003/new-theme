{% extends 'layouts/master.twig' %}

{% block content %}

<div class="cart-page">
  <div class="cart-page-inner">

    <div class="page-hero">
      <div class="page-hero-inner">
        <span class="section-tag">{{ 'your_cart' | trans }}</span>
        <h1 class="section-title">{{ 'cart' | trans }}</h1>
      </div>
    </div>

    {% if cart.items %}

      <div class="cart-layout">

        {# ─── CART ITEMS ─── #}
        <div class="cart-items">
          <table class="cart-table" role="table">
            <thead>
              <tr>
                <th scope="col">{{ 'product' | trans }}</th>
                <th scope="col">{{ 'price' | trans }}</th>
                <th scope="col">{{ 'quantity' | trans }}</th>
                <th scope="col">{{ 'total' | trans }}</th>
                <th scope="col"><span class="sr-only">{{ 'remove' | trans }}</span></th>
              </tr>
            </thead>
            <tbody>
              {% for item in cart.items %}
                <tr class="cart-row" data-item-id="{{ item.id }}">

                  {# Product Info #}
                  <td class="cart-product">
                    <a href="{{ item.product.url }}" class="cart-img-link">
                      <img src="{{ item.product.image.url }}" alt="{{ item.product.name }}" width="80" height="107" loading="lazy">
                    </a>
                    <div class="cart-product-info">
                      <a href="{{ item.product.url }}" class="cart-product-name">{{ item.product.name }}</a>
                      {% if item.options %}
                        <ul class="cart-options">
                          {% for option in item.options %}
                            <li>{{ option.name }}: <strong>{{ option.value }}</strong></li>
                          {% endfor %}
                        </ul>
                      {% endif %}
                      {% if item.product.sku %}
                        <span class="cart-sku">SKU: {{ item.product.sku }}</span>
                      {% endif %}
                    </div>
                  </td>

                  {# Price #}
                  <td class="cart-price" data-label="{{ 'price' | trans }}">
                    <salla-price amount="{{ item.price }}" currency="{{ store.currency }}"></salla-price>
                  </td>

                  {# Quantity #}
                  <td class="cart-qty" data-label="{{ 'quantity' | trans }}">
                    <salla-quantity-input
                      value="{{ item.quantity }}"
                      min="1"
                      max="{{ item.product.quantity }}"
                      item-id="{{ item.id }}"
                    ></salla-quantity-input>
                  </td>

                  {# Subtotal #}
                  <td class="cart-subtotal" data-label="{{ 'total' | trans }}">
                    <salla-price amount="{{ item.total }}" currency="{{ store.currency }}"></salla-price>
                  </td>

                  {# Remove #}
                  <td class="cart-remove">
                    <salla-remove-cart-item item-id="{{ item.id }}" aria-label="{{ 'remove' | trans }}">
                      <i class="sicon-close"></i>
                    </salla-remove-cart-item>
                  </td>

                </tr>
              {% endfor %}
            </tbody>
          </table>

          {# Coupon #}
          <div class="coupon-row">
            <salla-coupon></salla-coupon>
            <a href="{{ store.urls.products }}" class="btn-outline">
              {{ 'continue_shopping' | trans }}
            </a>
          </div>
        </div>

        {# ─── ORDER SUMMARY ─── #}
        <aside class="cart-summary" aria-label="{{ 'order_summary' | trans }}">
          <h2 class="summary-title">{{ 'order_summary' | trans }}</h2>

          <div class="summary-rows">
            <div class="summary-row">
              <span>{{ 'subtotal' | trans }}</span>
              <salla-price amount="{{ cart.subtotal }}" currency="{{ store.currency }}"></salla-price>
            </div>
            {% if cart.discount %}
              <div class="summary-row summary-discount">
                <span>{{ 'discount' | trans }}</span>
                <salla-price amount="{{ cart.discount }}" currency="{{ store.currency }}"></salla-price>
              </div>
            {% endif %}
            {% if cart.shipping %}
              <div class="summary-row">
                <span>{{ 'shipping' | trans }}</span>
                <salla-price amount="{{ cart.shipping }}" currency="{{ store.currency }}"></salla-price>
              </div>
            {% endif %}
            {% if cart.tax %}
              <div class="summary-row">
                <span>{{ 'tax' | trans }}</span>
                <salla-price amount="{{ cart.tax }}" currency="{{ store.currency }}"></salla-price>
              </div>
            {% endif %}
            <div class="summary-row summary-total">
              <span>{{ 'total' | trans }}</span>
              <salla-price amount="{{ cart.total }}" currency="{{ store.currency }}" class="total-price"></salla-price>
            </div>
          </div>

          <a href="{{ store.urls.checkout }}" class="btn-primary checkout-btn">
            <span>{{ 'proceed_to_checkout' | trans }}</span>
          </a>

          <div class="payment-icons-row">
            <salla-payments-icons></salla-payments-icons>
          </div>
        </aside>

      </div>

    {% else %}

      {# ─── EMPTY CART ─── #}
      <div class="empty-state">
        <div class="empty-icon">🛍️</div>
        <h2>{{ 'cart_is_empty' | trans }}</h2>
        <p>{{ 'add_something_beautiful' | trans }}</p>
        <a href="{{ store.urls.products }}" class="btn-primary">
          <span>{{ 'start_shopping' | trans }}</span>
        </a>
      </div>

    {% endif %}

  </div>
</div>

{% endblock %}
