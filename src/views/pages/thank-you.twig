{% extends 'layouts/master.twig' %}

{% block content %}

<div class="thankyou-page">
  <div class="thankyou-inner">

    {# ─── SUCCESS HEADER ─── #}
    <div class="thankyou-header reveal">
      <div class="success-icon" aria-hidden="true">✦</div>
      <h1>{{ 'thank_you' | trans }}</h1>
      <p class="thankyou-sub">{{ 'order_confirmed' | trans }}</p>
      <p class="order-num">
        {{ 'order_number' | trans }}: <strong>#{{ order.reference_id }}</strong>
      </p>
    </div>

    <div class="thankyou-layout reveal">

      {# ─── ORDER DETAILS ─── #}
      <div class="order-details">
        <h2>{{ 'order_details' | trans }}</h2>

        {# Items #}
        <div class="order-items">
          {% for item in order.items %}
            <div class="order-item">
              <img src="{{ item.product.image.url }}" alt="{{ item.product.name }}" width="72" height="96" loading="lazy">
              <div class="order-item-info">
                <p class="order-item-name">{{ item.product.name }}</p>
                {% if item.options %}
                  <p class="order-item-options">
                    {% for opt in item.options %}{{ opt.name }}: {{ opt.value }}{% if not loop.last %} · {% endif %}{% endfor %}
                  </p>
                {% endif %}
                <p class="order-item-qty">{{ 'quantity' | trans }}: {{ item.quantity }}</p>
              </div>
              <div class="order-item-price">
                <salla-price amount="{{ item.total }}" currency="{{ store.currency }}"></salla-price>
              </div>
            </div>
          {% endfor %}
        </div>

        {# Totals #}
        <div class="order-totals">
          <div class="summary-row">
            <span>{{ 'subtotal' | trans }}</span>
            <salla-price amount="{{ order.subtotal }}" currency="{{ store.currency }}"></salla-price>
          </div>
          {% if order.discount %}
            <div class="summary-row">
              <span>{{ 'discount' | trans }}</span>
              <salla-price amount="{{ order.discount }}" currency="{{ store.currency }}"></salla-price>
            </div>
          {% endif %}
          {% if order.shipping %}
            <div class="summary-row">
              <span>{{ 'shipping' | trans }}</span>
              <salla-price amount="{{ order.shipping }}" currency="{{ store.currency }}"></salla-price>
            </div>
          {% endif %}
          {% if order.tax %}
            <div class="summary-row">
              <span>{{ 'tax' | trans }}</span>
              <salla-price amount="{{ order.tax }}" currency="{{ store.currency }}"></salla-price>
            </div>
          {% endif %}
          <div class="summary-row summary-total">
            <span>{{ 'total' | trans }}</span>
            <salla-price amount="{{ order.total }}" currency="{{ store.currency }}" class="total-price"></salla-price>
          </div>
        </div>
      </div>

      {# ─── CUSTOMER + SHIPPING INFO ─── #}
      <div class="order-sidebar">

        <div class="info-card">
          <h3>{{ 'customer_info' | trans }}</h3>
          <p>{{ order.customer.name }}</p>
          <p>{{ order.customer.email }}</p>
          {% if order.customer.phone %}
            <p>{{ order.customer.phone }}</p>
          {% endif %}
        </div>

        <div class="info-card">
          <h3>{{ 'shipping_address' | trans }}</h3>
          <p>{{ order.shipping_address.street }}</p>
          <p>{{ order.shipping_address.city }}{% if order.shipping_address.state %}, {{ order.shipping_address.state }}{% endif %}</p>
          <p>{{ order.shipping_address.country }}</p>
        </div>

        <div class="info-card">
          <h3>{{ 'payment_method' | trans }}</h3>
          <p>{{ order.payment_method }}</p>
        </div>

        <div class="info-card">
          <h3>{{ 'shipping_method' | trans }}</h3>
          <p>{{ order.shipping_company }}</p>
          {% if order.estimated_delivery %}
            <p class="estimated-date">
              {{ 'estimated_delivery' | trans }}: {{ order.estimated_delivery | date("d M Y") }}
            </p>
          {% endif %}
        </div>

      </div>
    </div>

    {# ─── CTA ─── #}
    <div class="thankyou-actions reveal">
      <a href="{{ store.urls.products }}" class="btn-primary">
        <span>{{ 'continue_shopping' | trans }}</span>
      </a>
      {% if customer %}
        <a href="{{ store.urls.orders }}" class="btn-outline">
          {{ 'my_orders' | trans }}
        </a>
      {% endif %}
    </div>

  </div>
</div>

{% endblock %}
