{# ── شريط الإعلانات العلوي ── #}
<div class="announcement" role="banner" aria-label="إعلانات المتجر">
  <div class="announcement-track">
    {% if theme.settings.get('announcement_text_1') %}
      <span>{{ theme.settings.get('announcement_text_1') }}</span>
    {% else %}
      <span>توصيل مجاني على الطلبات فوق 300 ريال</span>
    {% endif %}

    {% if theme.settings.get('announcement_text_2') %}
      <span>{{ theme.settings.get('announcement_text_2') }}</span>
    {% else %}
      <span>تشكيلة الموسم الجديدة متاحة الآن</span>
    {% endif %}

    {% if theme.settings.get('announcement_text_3') %}
      <span>{{ theme.settings.get('announcement_text_3') }}</span>
    {% else %}
      <span>إرجاع مجاني خلال 14 يوم</span>
    {% endif %}

    {% if theme.settings.get('announcement_text_4') %}
      <span>{{ theme.settings.get('announcement_text_4') }}</span>
    {% else %}
      <span>كود خصم NASMA15 للطلب الأول</span>
    {% endif %}

    {# تكرار للانيميشن ── #}
