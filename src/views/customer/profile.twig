{% extends 'layouts/master.twig' %}

{% block content %}

<div class="account-page">
  <div class="account-inner">

    {# ─── SIDEBAR ─── #}
    <aside class="account-sidebar">
      <div class="account-avatar">
        <div class="avatar-circle">{{ customer.name | first }}</div>
        <div>
          <p class="avatar-name">{{ customer.name }}</p>
          <p class="avatar-email">{{ customer.email }}</p>
        </div>
      </div>

      <nav class="account-nav" aria-label="{{ 'account_menu' | trans }}">
        <a href="{{ store.urls.profile }}" class="account-nav-link {% if page.type == 'profile' %}active{% endif %}">
          <i class="sicon-user"></i> {{ 'my_account' | trans }}
        </a>
        <a href="{{ store.urls.orders }}" class="account-nav-link {% if page.type == 'orders' %}active{% endif %}">
          <i class="sicon-bag"></i> {{ 'my_orders' | trans }}
        </a>
        <a href="{{ store.urls.wishlist }}" class="account-nav-link {% if page.type == 'wishlist' %}active{% endif %}">
          <i class="sicon-heart"></i> {{ 'wishlist' | trans }}
        </a>
        <a href="{{ store.urls.addresses }}" class="account-nav-link">
          <i class="sicon-location"></i> {{ 'my_addresses' | trans }}
        </a>
        <a href="{{ store.urls.logout }}" class="account-nav-link account-logout">
          <i class="sicon-logout"></i> {{ 'logout' | trans }}
        </a>
      </nav>
    </aside>

    {# ─── MAIN CONTENT ─── #}
    <div class="account-main">
      <h1 class="account-title">{{ 'my_account' | trans }}</h1>

      <form class="profile-form" method="post" action="{{ store.urls.profile_update }}">
        {{ csrf_field() }}

        <div class="form-row">
          <div class="form-group">
            <label for="first_name">{{ 'first_name' | trans }}</label>
            <input type="text" id="first_name" name="first_name" value="{{ customer.first_name }}" required>
          </div>
          <div class="form-group">
            <label for="last_name">{{ 'last_name' | trans }}</label>
            <input type="text" id="last_name" name="last_name" value="{{ customer.last_name }}" required>
          </div>
        </div>

        <div class="form-group">
          <label for="email">{{ 'email' | trans }}</label>
          <input type="email" id="email" name="email" value="{{ customer.email }}" required>
        </div>

        <div class="form-group">
          <label for="phone">{{ 'phone' | trans }}</label>
          <input type="tel" id="phone" name="phone" value="{{ customer.phone }}">
        </div>

        <div class="form-divider"></div>
        <h3 class="form-section-title">{{ 'change_password' | trans }}</h3>

        <div class="form-group">
          <label for="current_password">{{ 'current_password' | trans }}</label>
          <input type="password" id="current_password" name="current_password" autocomplete="current-password">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="new_password">{{ 'new_password' | trans }}</label>
            <input type="password" id="new_password" name="new_password" autocomplete="new-password">
          </div>
          <div class="form-group">
            <label for="confirm_password">{{ 'confirm_password' | trans }}</label>
            <input type="password" id="confirm_password" name="confirm_password" autocomplete="new-password">
          </div>
        </div>

        <button type="submit" class="btn-primary">
          <span>{{ 'save_changes' | trans }}</span>
        </button>
      </form>
    </div>

  </div>
</div>

{% endblock %}
