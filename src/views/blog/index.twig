{% extends 'layouts/master.twig' %}
{% block content %}
<div class="page-hero">
  <div class="page-hero-inner">
    <span class="section-tag">{{ 'our_blog' | trans }}</span>
    <h1 class="section-title">{{ 'blog' | trans }}</h1>
  </div>
</div>
<div class="section">
  <div class="blog-grid">
    {% for post in blog.posts %}
      <a href="{{ post.url }}" class="blog-card reveal">
        {% if post.image %}
          <div class="blog-img-wrap">
            <img src="{{ post.image }}" alt="{{ post.title }}" loading="lazy">
          </div>
        {% endif %}
        <div class="blog-info">
          <span class="blog-date">{{ post.created_at | date("d M Y") }}</span>
          <h2 class="blog-title">{{ post.title }}</h2>
          <p class="blog-excerpt">{{ post.excerpt }}</p>
          <span class="blog-read-more">{{ 'read_more' | trans }} ←</span>
        </div>
      </a>
    {% endfor %}
  </div>
</div>
{% endblock %}
