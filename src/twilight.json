{
  "version": "1.0.0",
  "theme_name": "نسمة",
  "repo_url": "https://github.com/YOUR_USERNAME/nasma-theme",
  "support_url": "https://salla.dev",
  "author_email": "your@email.com",
  "direction": "rtl",
  "features": [
    "mega-menu",
    "fonts",
    "color",
    "breadcrumb",
    "unite-cards-height",
    "component-featured-products",
    "component-fixed-banner",
    "component-products-slider",
    "component-photos-slider",
    "component-testimonials",
    "component-store-features",
    "filters"
  ],
  "settings": [
    {
      "id": "color_primary",
      "type": "color",
      "label": "اللون الذهبي",
      "default": "#B8955A"
    },
    {
      "id": "color_deep",
      "type": "color",
      "label": "اللون الداكن",
      "default": "#1A1614"
    },
    {
      "id": "color_cream",
      "type": "color",
      "label": "لون الكريم",
      "default": "#F5F0E8"
    },
    {
      "id": "color_bg",
      "type": "color",
      "label": "لون الخلفية",
      "default": "#FAF8F4"
    },
    {
      "id": "announcement_text",
      "type": "text",
      "label": "نص شريط الإعلانات",
      "default": "توصيل مجاني للطلبات فوق 299 ريال"
    },
    {
      "id": "show_announcement",
      "type": "checkbox",
      "label": "إظهار شريط الإعلانات",
      "default": true
    },
    {
      "id": "hero_title_en",
      "type": "text",
      "label": "عنوان الهيرو (إنجليزي)",
      "default": "Elegance"
    },
    {
      "id": "hero_title_ar",
      "type": "text",
      "label": "عنوان الهيرو (عربي)",
      "default": "فن العباية الفاخرة"
    },
    {
      "id": "hero_desc",
      "type": "textarea",
      "label": "وصف الهيرو",
      "default": "تصاميم تجمع بين الأصالة السعودية والأناقة المعاصرة، مصنوعة بأجود الخامات لتعكس شخصيتك المميزة."
    },
    {
      "id": "hero_image",
      "type": "image",
      "label": "صورة الهيرو"
    },
    {
      "id": "hero_btn_primary",
      "type": "text",
      "label": "نص الزر الرئيسي",
      "default": "تسوقي الآن"
    },
    {
      "id": "hero_btn_secondary",
      "type": "text",
      "label": "نص الزر الثاني",
      "default": "تعرفي علينا"
    },
    {
      "id": "promo_title",
      "type": "text",
      "label": "عنوان بانر العروض",
      "default": "كولكشن الربيع"
    },
    {
      "id": "promo_discount",
      "type": "text",
      "label": "نص الخصم",
      "default": "خصم حتى ٤٠٪"
    },
    {
      "id": "promo_end_date",
      "type": "text",
      "label": "تاريخ انتهاء العرض (YYYY-MM-DD)",
      "default": ""
    }
  ]
}
